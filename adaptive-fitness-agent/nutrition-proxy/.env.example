PORT=4000

# Firebase Admin credentials used by coach routes and verified email signup.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Branded signup OTP email delivery through plain Nodemailer SMTP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM="AdaptFit <no-reply@example.com>"
SMTP_USER=
SMTP_PASS=
AUTH_OTP_HASH_SECRET=
AUTH_OTP_TTL_SECONDS=600
AUTH_OTP_RESEND_SECONDS=60
AUTH_OTP_MAX_ATTEMPTS=5

# Local-only fallback. Set true to print OTPs to the proxy console if SMTP is not configured.
EMAIL_DEV_LOG_OTP=false

# Existing nutrition, vision, coach, and cache settings.
USDA_API_KEY=
OPENFOODFACTS_USER_AGENT="AdaptiveFitnessAgent/1.0 (contact@example.com)"
GOOGLE_VISION_PROJECT_ID=
GOOGLE_VISION_CLIENT_EMAIL=
GOOGLE_VISION_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
REDIS_URL=

# Event-driven intelligence, cache, observability, and prompt compression.
QUEUE_ENABLED=true
INTELLIGENCE_WORKER_CONCURRENCY=3
INTELLIGENCE_EVENT_WINDOW_DAYS=30
REDIS_CACHE_ENABLED=true
REDIS_KEY_PREFIX=adaptive_fitness
MEMORY_CACHE_MAX_ITEMS=500
MEMORY_CACHE_TTL_MS=60000
SIGNAL_CACHE_TTL_SECONDS=300
COACH_PROMPT_TOKEN_BUDGET=1200
AI_PROVIDER=gemini
LOG_LEVEL=info
